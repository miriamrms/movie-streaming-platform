generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id        String   @id @default(uuid())
  title     String?  // O '?' significa que pode ser nulo (para testar o teu fallback)
  file_name String?
  synopsis  String?
  genres    String?
  duration  String?
  director  String?
  cast      String?
  createdAt DateTime  @default(now())
  histories History[]
}

model History {
  id_user       String
  id_movie      String
  watched_at    DateTime @db.Date
  duration      Int
  last_position Int      @default(0)
  is_completed  Boolean  @default(false)
  is_hidden     Boolean  @default(false)

  movie Movie @relation(fields: [id_movie], references: [id])

  @@id([id_user, id_movie, watched_at])
}
